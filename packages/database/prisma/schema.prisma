generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeviceType {
  CAMERA
  CONTROLLER
  SENSOR
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  DEGRADED
  MAINTENANCE
}

model SecurityDevice {
  id            String       @id @default(uuid())
  name          String
  type          DeviceType
  status        DeviceStatus @default(OFFLINE)
  ipAddress     String?
  location      String?
  lastHeartbeat DateTime?
  metadata      Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}